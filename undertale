#!/usr/bin/env bash
# UNDERTALE TERMINAL - Launch script
# Run from anywhere: just type 'undertale'

GAME_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
VENV_PYTHON="$GAME_DIR/.venv/bin/python3"

# Ensure pygame is available via the venv
if [ -x "$VENV_PYTHON" ]; then
    cd "$GAME_DIR" && exec "$VENV_PYTHON" main.py "$@"
else
    cd "$GAME_DIR" && exec python3 main.py "$@"
fi
